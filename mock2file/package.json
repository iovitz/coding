{
  "name": "mock2file",
  "version": "1.0.1",
  "description": "mock2file is a command line tool that parses the mock syntax in JSON files and exports the parsed mock data to a new file",
  "main": "dist/main.cjs.js",
  "module": "dist/main.esm.js",
  "unpkg": "dist/main.min.js",
  "bin": {
    "m2f": "dist/main.mjs"
  },
  "scripts": {
    "dev": "rollup -cw",
    "build": "rollup -c --environment NODE_ENV:production && rollup -c",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "iovitz",
  "license": "ISC",
  "dependencies": {
    "@types/commander": "^2.12.2",
    "axios": "^0.24.0",
    "colors": "^1.4.0",
    "commander": "^8.3.0",
    "downgrade-root": "^2.0.0",
    "json-as-xlsx": "^2.2.3",
    "lodash": "^4.17.21",
    "mockjs": "^1.1.0",
    "npmlog": "^5.0.1",
    "path-exists": "^5.0.0",
    "rollup-plugin-json": "^4.0.0",
    "semver": "^7.3.5",
    "sudo-block": "^4.0.0",
    "url-join": "^4.0.1"
  },
  "devDependencies": {
    "@types/mockjs": "^1.0.4",
    "@types/node": "^16.11.7",
    "@types/npmlog": "^4.1.3",
    "@types/root-check": "^1.0.0",
    "@types/semver": "^7.3.9",
    "@types/url-join": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^5.3.1",
    "@typescript-eslint/parser": "^5.3.1",
    "eslint": "^8.2.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^5.1.1",
    "rollup": "^2.60.0",
    "rollup-plugin-typescript2": "^0.30.0",
    "typescript": "^4.4.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iovitz/mock2file.git"
  },
  "keywords": [
